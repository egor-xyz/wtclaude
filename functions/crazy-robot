#autoload
# crazy-robot — render one frame of the animated robot mascot.
# Usage:   crazy-robot <track_width>
# Reads/writes shared state vars (caller must declare local before loop):
#   _robot_state, _robot_t, _robot_dur, _robot_pos, _robot_dir
# Prints robot lines to stdout in orange ANSI; no trailing color reset issues.

emulate -L zsh
setopt extended_glob no_xtrace no_verbose typeset_silent

local track=${1:-30}
(( track < 1 )) && track=1

# Body uses U+2501 (━) instead of `===` to avoid `|=` and `===` ligatures
# triggered by FiraCode-like fonts. Each ━ is a single-codepoint glyph so the
# shaper cannot combine adjacent chars into a ligature.
local -a walk_frames idle_frames
walk_frames=(
$'  .-----.\n  [o   o]\n  /|━━━|\\\n   o   o'
$'  .-----.\n  [o   o]\n  /|━━━|\\\n   O   O'
)
idle_frames=(
$'  .-----.\n  [- - -]\n  /|━━━|\\\n   o   o'
$'  .-----.\n  [o   o]\n  /|━━━|\\\n   o   o'
$'  .-----.\\o\n  [o   o]\n   |━━━|\n   o   o'
$'  .-----.\n  [^   ^]\n  /|━━━|\\\n   o   o'
$'  .-----.\n  [o   o]\n  /|━u━|\\\n   o   o'
$' \\.-----./\n  [O   O]\n   |━━━|\n   o   o'
$'  .-----.\n  [- _ -]\n  /|━━━|\\\n   o   o'
$'  .-----.\n  [O   O]\n  /|━O━|\\\n   o   o'
$'  .-----.\n  [O   O]\n  /|━━━|\\\n   ~   ~'
$'  .-----.\n  [O   O]\n   |━━━|\n   \'   \''
)

# Pick new state when current expires
if (( _robot_t >= _robot_dur )); then
  # Slot machine intentionally excluded — only triggered by Space (easter egg)
  local -a states=(walk walk static blink wave sleep surprise smile dance jump)
  [[ $_robot_state == slot ]] && states=(walk)
  _robot_state=${states[$((RANDOM % ${#states} + 1))]}
  _robot_t=0
  _robot_dur=$(( 4 + RANDOM % 9 ))
fi

local raw color
# Color per state — dance/jump cycle a rainbow palette
local -a rainbow=(208 220 46 51 75 99 165 213)
case $_robot_state in
  walk)     color=208 ;;  # orange
  static)   color=244 ;;  # grey
  blink)    color=214 ;;  # amber
  wave)     color=220 ;;  # yellow
  surprise) color=214 ;;  # amber
  smile)    color=213 ;;  # pink
  sleep)    color=63  ;;  # blue
  dance)    color=${rainbow[$((_robot_t % ${#rainbow} + 1))]} ;;
  jump)     color=${rainbow[$((_robot_t % ${#rainbow} + 1))]} ;;
  slot)     color=226 ;;  # yellow (jackpot overrides below)
esac
case $_robot_state in
  walk)
    _robot_pos=$(( _robot_pos + _robot_dir ))
    if (( _robot_pos >= track - 1 )); then _robot_pos=$((track - 1)); _robot_dir=-1; fi
    if (( _robot_pos <= 0 )); then _robot_pos=0; _robot_dir=1; fi
    raw=${walk_frames[$((_robot_t % ${#walk_frames} + 1))]}
    ;;
  static)   raw=${walk_frames[1]} ;;
  blink)    raw=${idle_frames[$((_robot_t % 2 == 0 ? 1 : 2))]} ;;
  wave)     raw=${idle_frames[3]} ;;
  surprise) raw=${idle_frames[4]} ;;
  smile)    raw=${idle_frames[5]} ;;
  sleep)    raw=${idle_frames[7]} ;;
  dance)    raw=${idle_frames[$((_robot_t % 2 == 0 ? 6 : 2))]} ;;
  jump)     raw=${idle_frames[$((_robot_t % 2 == 0 ? 9 : 10))]} ;;
  slot)
    # Reel symbols. 7️⃣ keycap is the jackpot — width matches the other 2-col
    # emojis in modern terminals.
    local -a syms=('🍒' '🍋' '🍇' '🔔' '⭐' '💎' '7️⃣')
    # Timing: pull lever, then reels spin and slow down, stop one by one.
    local pull_end=1
    local stop1=8 stop2=13 stop3=18
    _robot_pos=0

    # At tick 0, decide the final outcome.
    if (( _robot_t == 0 )); then
      _robot_locked=""
      _robot_f1=${syms[$((RANDOM % ${#syms} + 1))]}
      _robot_f2=${syms[$((RANDOM % ${#syms} + 1))]}
      _robot_f3=${syms[$((RANDOM % ${#syms} + 1))]}
      (( RANDOM % 100 < 15 )) && { _robot_f1='7️⃣'; _robot_f2='7️⃣'; _robot_f3='7️⃣'; }
      _robot_s1='❓'; _robot_s2='❓'; _robot_s3='❓'   # placeholders during pull
    fi

    # While the lever is being pulled, reels stay still.
    if (( _robot_t >= pull_end )); then
      # Per-reel "rotation": rate slows as the reel approaches its stop tick.
      _wt_reel_rate() {
        # arg: ticks remaining until this reel stops
        local r=$1
        if   (( r > 5 )); then echo 1
        elif (( r > 2 )); then echo 2
        else                    echo 3
        fi
      }
      local rate
      local rem1=$(( stop1 - _robot_t ))
      local rem2=$(( stop2 - _robot_t ))
      local rem3=$(( stop3 - _robot_t ))

      if (( _robot_t < stop1 )); then
        rate=$(_wt_reel_rate $rem1)
        (( (_robot_t - pull_end) % rate == 0 )) && _robot_s1=${syms[$((RANDOM % ${#syms} + 1))]}
      else
        _robot_s1=$_robot_f1
      fi
      if (( _robot_t < stop2 )); then
        rate=$(_wt_reel_rate $rem2)
        (( (_robot_t - pull_end) % rate == 0 )) && _robot_s2=${syms[$((RANDOM % ${#syms} + 1))]}
      else
        _robot_s2=$_robot_f2
      fi
      if (( _robot_t < stop3 )); then
        rate=$(_wt_reel_rate $rem3)
        (( (_robot_t - pull_end) % rate == 0 )) && _robot_s3=${syms[$((RANDOM % ${#syms} + 1))]}
      else
        _robot_s3=$_robot_f3
      fi
    fi

    # Fully locked only after the last reel stops.
    if (( _robot_t >= stop3 )); then
      _robot_locked=1
    fi

    local jackpot=0
    [[ -n $_robot_locked && $_robot_f1 == '7️⃣' && $_robot_f2 == '7️⃣' && $_robot_f3 == '7️⃣' ]] && jackpot=1

    # Steady color so the emoji reels stay readable. Only the surrounding
    # sparkles (on jackpot) get the rainbow treatment.
    local slot_color=226   # yellow

    local orange=$'\e[38;5;208m'
    local sc=$'\e[38;5;'"$slot_color"'m'
    local reset=$'\e[39m'

    # Robot uses existing frames. First tick = pulling the lever (arm up).
    # After that the robot stands still while the reels spin, then reacts to
    # the result (jump on jackpot, sad on loss).
    local frame
    if (( _robot_t == 0 )); then
      frame=${idle_frames[3]}     # arm-up — pulling the lever
    elif [[ -z $_robot_locked ]]; then
      frame=${idle_frames[2]}     # standing still, waiting
    elif (( jackpot )); then
      frame=${idle_frames[$(( _robot_t % 2 == 0 ? 9 : 10 ))]}
    else
      frame=${idle_frames[7]}     # sad/slumped
    fi
    local -a r_lines=("${(@f)frame}")

    # Slot machine — 16-col body sized for 2-col emoji reels + side lever knob.
    # Knob position animates the pull: row 1 (up) at t=0, row 2 (mid) while
    # spinning, row 3 (down) after the reels lock.
    local m1 m2 m3 m4
    local base1='.--------------.'
    local base2="| ${_robot_s1} | ${_robot_s2} | ${_robot_s3} |"
    local base3='| -- | -- | -- |'
    local base4="'----[o-o-o]---'"
    if (( _robot_t == 0 )); then
      # Pull moment: lever knob up high, robot grabbing it
      m1="${base1} o"
      m2="${base2}/"
      m3="${base3}"
      m4="${base4}"
    else
      # Pulled: lever knob rests at the bottom while reels spin and lock
      m1="${base1}"
      m2="${base2}"
      m3="${base3}---o"
      m4="${base4}"
    fi

    # No sparkle decoration around the machine — it shifted m1/m4 widths and
    # broke alignment. Celebration is conveyed by the robot's jump frames.

    # Machine on the left, robot pinned to absolute column on the right.
    # The trailing \e[K after the machine clears any stale chars (from the
    # previous frame's lever extension) before the robot is drawn.
    local rc=18
    printf '%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$sc" "$m1" "$reset" "$rc" "$orange" "${r_lines[1]}" "$reset"
    printf '%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$sc" "$m2" "$reset" "$rc" "$orange" "${r_lines[2]}" "$reset"
    printf '%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$sc" "$m3" "$reset" "$rc" "$orange" "${r_lines[3]}" "$reset"
    printf '%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$sc" "$m4" "$reset" "$rc" "$orange" "${r_lines[4]}" "$reset"
    (( _robot_t++ ))
    return
    ;;
esac
(( _robot_t++ ))

local pad=""
local _p
for ((_p=0; _p<_robot_pos; _p++)); do pad+=" "; done
local body=${raw//$'\n'/$'\n'$pad}
# Body stays orange; only expression chars between [...] take state color.
local orange=$'\e[38;5;208m'
local accent=$'\e[38;5;'"$color"'m'
local reset=$'\e[39m'
local highlighted=${body//(#b)\[([^]]*)\]/\[${accent}${match[1]}${orange}\]}
# Append \e[K to every line so each row clears its tail when redrawn
highlighted=${highlighted//$'\n'/$'\e[K\n'}
printf '%s%s%s%s\e[K\n' "$orange" "$pad" "$highlighted" "$reset"
