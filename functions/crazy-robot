#autoload
# crazy-robot — render one frame of the animated robot mascot.
# Usage:   crazy-robot <track_width>
# Reads/writes shared state vars (caller must declare local before loop):
#   _robot_state, _robot_t, _robot_dur, _robot_pos, _robot_dir
# Prints robot lines to stdout in orange ANSI; no trailing color reset issues.

emulate -L zsh
setopt extended_glob no_xtrace no_verbose typeset_silent

local track=${1:-30}
(( track < 1 )) && track=1

# Body uses U+2501 (━) instead of `===` to avoid `|=` and `===` ligatures
# triggered by FiraCode-like fonts. Each ━ is a single-codepoint glyph so the
# shaper cannot combine adjacent chars into a ligature.
local -a walk_frames idle_frames
walk_frames=(
$'  .-----.\n  [o   o]\n  /|━━━|\\\n   o   o'
$'  .-----.\n  [o   o]\n  /|━━━|\\\n   O   O'
)
idle_frames=(
$'  .-----.\n  [- - -]\n  /|━━━|\\\n   o   o'
$'  .-----.\n  [o   o]\n  /|━━━|\\\n   o   o'
$'  .-----.\\o\n  [o   o]\n   |━━━|\n   o   o'
$'  .-----.\n  [^   ^]\n  /|━━━|\\\n   o   o'
$'  .-----.\n  [o   o]\n  /|━u━|\\\n   o   o'
$' \\.-----./\n  [O   O]\n   |━━━|\n   o   o'
$'  .-----.\n  [- _ -]\n  /|━━━|\\\n   o   o'
$'  .-----.\n  [O   O]\n  /|━O━|\\\n   o   o'
$'  .-----.\n  [O   O]\n  /|━━━|\\\n   ~   ~'
$'  .-----.\n  [O   O]\n   |━━━|\n   \'   \''
$'  .-----.         🌙\n  [- - O]    ==o\n  /|━━━|\\    |\n   o   o    / \\'
$'  .-----.   ·     🌙\n  [- - -]    ==o\n  /|━━━|\\    |\n   o   o    / \\'
$'\n\n\n'
$'  /\\   /\\\n  .-----.\n  [o   o]\n'
$'  /\\   /\\\n  .-----.\n  [- - -]\n'
$'  .-----.\n  [⌐   ⌐]🏀  --|_|\n  /|━━━|━       |\n   o   o        |'
$'  .-----.  🏀\n  [⌐   ⌐]    --|_|\n  /|━━━|━       |\n   o   o        |'
$'  .-----.    🏀\n  [⌐   ⌐]    --|_|\n  /|━━━|\\       |\n   o   o        |'
$'  .-----.\n  [⌐   ⌐]    🏀|_|\n  /|━━━|\\       |\n   o   o        |'
$'  .-----.\n  [^   ^]    --|_|\n  /|━━━|\\     🏀|\n   o   o        |'
$'  .-----.\n  [^   ^]✨  --|_|\n  /|━━━|\\       |\n   o   o      🏀|'
$'  .-----.\n  [o   o]\n  /|━━━|━━o\n   o   o  🔥'
$'  .-----.\n  [o   o]  ·\n  /|━━━|━━o\n   o   o  💥'
$'  .-----.\n  [-   -]\n  /|━━━|━━o\n   o   o  ✨'
$'  .-----.\n  [o   o]\no━━|━━━|\\\n🔥 o   o'
$'  .-----.\n· [o   o]\no━━|━━━|\\\n💥 o   o'
$'  .-----.\n  [-   -]\no━━|━━━|\\\n✨ o   o'
$'         .-----.\n|_|--  🏀[⌐   ⌐]\n |       ━|━━━|\\\n |        o   o'
$'     🏀  .-----.\n|_|--    [⌐   ⌐]\n |       ━|━━━|\\\n |        o   o'
$'   🏀    .-----.\n|_|--    [⌐   ⌐]\n |       /|━━━|\\\n |        o   o'
$'         .-----.\n|_|🏀    [⌐   ⌐]\n |       /|━━━|\\\n |        o   o'
$'         .-----.\n|_|--    [^   ^]\n |🏀     /|━━━|\\\n |        o   o'
$'         .-----.\n|_|--  ✨[^   ^]\n |       /|━━━|\\\n |🏀      o   o'
$'  .-----.\n  [o   o]\n  /|━━━|━━━\\\n   o   o  ~~o~~'
$'  .-----.\n  [-   -]\n  /|━━━|━━━\\\n   o   o  ~~~~~'
$'  .-----.  🐟\n  [^   ^]━━/✨\n  /|━━━|\n   o   o  ~~~~~'
$'         .-----.\n         [o   o]\n      /━━━|━━━|\\\n   ~~o~~  o   o'
$'         .-----.\n         [-   -]\n      /━━━|━━━|\\\n   ~~~~~  o   o'
$'     🐟  .-----.\n    ✨\\━━[^   ^]\n          |━━━|\\\n   ~~~~~  o   o'
$'  .-----.\n  [-   -] ~\n  /|━━━|━☕\n   o   o'
$'  .-----.\n  [-   -]  ~\n  /|━━━|━☕\n   o   o'
$'  .-----.\n  [-   -]☕\n  /|━━━|/\n   o   o'
$'  .-----.\n  [O   O]\n  /|━━━|━☕\n   o   o'
$'         .-----.\n       ~ [-   -]\n       ☕━|━━━|\\\n          o   o'
$'         .-----.\n      ~  [-   -]\n       ☕━|━━━|\\\n          o   o'
$'         .-----.\n       ☕[-   -]\n         \\|━━━|\\\n          o   o'
$'         .-----.\n         [O   O]\n       ☕━|━━━|\\\n          o   o'
$'  .-----.\n  [o   o]\n  /|━━━|━o·\n   o   o  🌱'
$'  .-----.\n  [o   o]\n  /|━━━|━o\n   o   o  🌱'
$'  .-----.\n  [o   o]\n  /|━━━|━o·\n   o   o  🌿'
$'  .-----.\n  [o   o]\n  /|━━━|━o\n   o   o  🌿'
$'  .-----.\n  [^   ^]\n  /|━━━|\\\n   o   o  🌻'
$'         .-----.\n         [o   o]\n       ·o━|━━━|\\\n      🌱  o   o'
$'         .-----.\n         [o   o]\n        o━|━━━|\\\n      🌱  o   o'
$'         .-----.\n         [o   o]\n       ·o━|━━━|\\\n      🌿  o   o'
$'         .-----.\n         [o   o]\n        o━|━━━|\\\n      🌿  o   o'
$'         .-----.\n         [^   ^]\n         /|━━━|\\\n      🌻  o   o'
)

# Pick new state when current expires
if (( _robot_t >= _robot_dur )); then
  # Walk between every other animation so the robot moves around.
  # Slot machine intentionally excluded — only triggered by Space (easter egg).
  if [[ $_robot_state != walk ]]; then
    _robot_state=walk
  else
    local -a states=(static blink wave sleep surprise smile dance jump moon catpeek basketball campfire fishing coffee garden)
    _robot_state=${states[$((RANDOM % ${#states} + 1))]}
  fi
  _robot_t=0
  # Keep walk's final pos when switching to other states so the robot
  # stays put. Only clamp wide props (moon) since plain robot frames
  # already fit inside the walk track. catpeek picks its own pos per phase.
  local _w=0
  case $_robot_state in
    moon)                   _w=20 ;;
    basketball)             _w=18 ;;
    fishing)                _w=16 ;;
    campfire|coffee|garden) _w=13 ;;
  esac
  if (( _w )); then
    (( _robot_pos > track - _w )) && _robot_pos=$(( track - _w ))
    (( _robot_pos < 0 )) && _robot_pos=0
  fi
  # Per-state duration: short cycles repeat a few times, long cycles play 1-2x.
  # Always a whole number of cycles so the animation never cuts mid-loop.
  case $_robot_state in
    walk)              _robot_dur=$(( 12 + RANDOM % 16 )) ;;  # wander 12-27
    static|wave|smile) _robot_dur=$(( 12 + RANDOM % 10 )) ;;  # hold pose 12-21
    sleep)             _robot_dur=$(( 16 + RANDOM % 12 )) ;;  # nap 16-27
    surprise)          _robot_dur=$(( 6 + RANDOM % 6 )) ;;    # brief 6-11
    blink|dance)       _robot_dur=$(( (6 + RANDOM % 6) * 2 )) ;; # 6-11 ping-pongs
    jump)              _robot_dur=$(( (12 + RANDOM % 6) * 2 )) ;; # 12-17 jumps
    moon)              _robot_dur=$(( (6 + RANDOM % 4) * 6 )) ;; # 6-9 blink cycles
    catpeek)           _robot_dur=$(( (2 + RANDOM % 2) * 8 )) ;; # 2-3 peek loops
    basketball)        _robot_dur=$(( (2 + RANDOM % 3) * 6 )) ;; # 2-4 shot loops
    campfire)          _robot_dur=$(( (4 + RANDOM % 4) * 3 )) ;; # 4-7 flicker loops
    fishing)           _robot_dur=$(( (1 + RANDOM % 2) * 12 )) ;; # 1-2 catch loops
    coffee)            _robot_dur=$(( (1 + RANDOM % 2) * 12 )) ;; # 1-2 sip loops
    garden)            _robot_dur=$(( (1 + RANDOM % 2) * 12 )) ;; # 1-2 grow loops
    *)                 _robot_dur=$(( 8 + RANDOM % 18 )) ;;
  esac
fi

local raw color
# Color per state — dance/jump cycle a rainbow palette
local -a rainbow=(208 220 46 51 75 99 165 213)
case $_robot_state in
  walk)     color=208 ;;  # orange
  static)   color=244 ;;  # grey
  blink)    color=214 ;;  # amber
  wave)     color=220 ;;  # yellow
  surprise) color=214 ;;  # amber
  smile)    color=213 ;;  # pink
  sleep)    color=63  ;;  # blue
  dance)    color=${rainbow[$((_robot_t % ${#rainbow} + 1))]} ;;
  jump)     color=${rainbow[$((_robot_t % ${#rainbow} + 1))]} ;;
  moon)     color=75  ;;  # pale blue
  catpeek)  color=213 ;;  # pink
  basketball) color=214 ;;  # amber
  campfire) color=203 ;;  # warm red
  fishing)  color=39  ;;  # water blue
  coffee)   color=130 ;;  # coffee brown
  garden)   color=114 ;;  # leaf green
  slot)     color=226 ;;  # yellow (jackpot overrides below)
esac
case $_robot_state in
  walk)
    _robot_pos=$(( _robot_pos + _robot_dir ))
    if (( _robot_pos >= track - 1 )); then _robot_pos=$((track - 1)); _robot_dir=-1; fi
    if (( _robot_pos <= 0 )); then _robot_pos=0; _robot_dir=1; fi
    raw=${walk_frames[$((_robot_t % ${#walk_frames} + 1))]}
    ;;
  static)   raw=${walk_frames[1]} ;;
  blink)    raw=${idle_frames[$((_robot_t % 2 == 0 ? 1 : 2))]} ;;
  wave)     raw=${idle_frames[3]} ;;
  surprise) raw=${idle_frames[4]} ;;
  smile)    raw=${idle_frames[5]} ;;
  sleep)    raw=${idle_frames[7]} ;;
  dance)    raw=${idle_frames[$((_robot_t % 2 == 0 ? 6 : 2))]} ;;
  jump)     raw=${idle_frames[$((_robot_t % 2 == 0 ? 9 : 10))]} ;;
  moon)
    (( _robot_t == 0 )) && _robot_mirror=$(( RANDOM % 2 ))
    local -a moon_phases=('🌑' '🌒' '🌓' '🌔' '🌕' '🌖' '🌗' '🌘')
    local _mp=${moon_phases[$(( _robot_t / 3 % ${#moon_phases} + 1 ))]}
    local _eyes_r='- - O' _eyes_l='O - -' _spark=' '
    if (( _robot_t % 6 == 5 )); then _eyes_r='- - -'; _eyes_l='- - -'; _spark='·'; fi
    if (( _robot_mirror )); then
      raw="${_mp}    ${_spark}     .-----."$'\n'"     o==    [${_eyes_l}]"$'\n'$'       |    /|━━━|\\'$'\n'$'      / \\    o   o'
    else
      raw="  .-----.   ${_spark}     ${_mp}"$'\n'"  [${_eyes_r}]    ==o"$'\n'$'  /|━━━|\\    |'$'\n'$'   o   o    / \\'
    fi
    ;;
  catpeek)
    local phase=$(( _robot_t % 8 ))
    if (( phase == 0 )); then
      # Frame is ~10 cols wide incl. leading pad; clamp so it never wraps.
      local _cp_max=$(( track - 10 ))
      (( _cp_max < 1 )) && _cp_max=1
      _robot_pos=$(( RANDOM % _cp_max ))
    fi
    case $phase in
      2|4) raw=${idle_frames[14]} ;;
      3|5) raw=${idle_frames[15]} ;;
      *)   raw=${idle_frames[13]} ;;
    esac
    ;;
  basketball)
    # 6-tick cycle: aim → release → arc → rim → swish → bounce+✨.
    # Mirrored variant puts the hoop on the robot's left.
    (( _robot_t == 0 )) && _robot_mirror=$(( RANDOM % 2 ))
    raw=${idle_frames[$(( (_robot_mirror ? 28 : 16) + _robot_t % 6 ))]}
    ;;
  campfire)
    # 3-tick flicker: 🔥 flare → 💥 burst → ✨ embers (+ cozy blink).
    # Mirrored variant puts the fire on the robot's left.
    (( _robot_t == 0 )) && _robot_mirror=$(( RANDOM % 2 ))
    raw=${idle_frames[$(( (_robot_mirror ? 25 : 22) + _robot_t % 3 ))]}
    ;;
  fishing)
    # 12-tick cycle: bobber bobs (4 ticks) → 🐟 catch + ✨ (8 ticks).
    # Mirrored variant fishes off the robot's left.
    (( _robot_t == 0 )) && _robot_mirror=$(( RANDOM % 2 ))
    local _fb=$(( _robot_mirror ? 37 : 34 ))
    local _fp=$(( _robot_t % 12 ))
    if (( _fp >= 4 )); then
      raw=${idle_frames[$(( _fb + 2 ))]}
    else
      raw=${idle_frames[$(( _fb + _fp % 2 ))]}
    fi
    ;;
  coffee)
    # 12-tick cycle: sleepy + slow steam drift (6) → long sip (3) → awake O O (3).
    # Mirrored variant holds the cup in the left hand.
    (( _robot_t == 0 )) && _robot_mirror=$(( RANDOM % 2 ))
    local _cb=$(( _robot_mirror ? 44 : 40 ))
    local _cp=$(( _robot_t % 12 ))
    if (( _cp < 6 )); then
      raw=${idle_frames[$(( _cb + _cp / 3 ))]}
    elif (( _cp < 9 )); then
      raw=${idle_frames[$(( _cb + 2 ))]}
    else
      raw=${idle_frames[$(( _cb + 3 ))]}
    fi
    ;;
  garden)
    # 12-tick cycle: water 🌱 (4) → water 🌿 (4) → 🌻 blooms (4).
    # Water drop · falls on alternate ticks. Mirrored variant plants left.
    (( _robot_t == 0 )) && _robot_mirror=$(( RANDOM % 2 ))
    local _gb=$(( _robot_mirror ? 53 : 48 ))
    local _gp=$(( _robot_t % 12 ))
    if (( _gp < 8 )); then
      raw=${idle_frames[$(( _gb + _gp / 4 * 2 + _gp % 2 ))]}
    else
      raw=${idle_frames[$(( _gb + 4 ))]}
    fi
    ;;
  slot)
    # Reel symbols. 7️⃣ keycap is the jackpot — width matches the other 2-col
    # emojis in modern terminals.
    local -a syms=('🍒' '🍋' '🍇' '🔔' '⭐' '💎' '7️⃣')
    # Timing: pull lever, then reels spin and slow down, stop one by one.
    local pull_end=1
    local stop1=8 stop2=13 stop3=18
    _robot_pos=0

    # At tick 0, decide the final outcome.
    if (( _robot_t == 0 )); then
      _robot_mirror=$(( RANDOM % 2 ))
      _robot_locked=""
      _robot_f1=${syms[$((RANDOM % ${#syms} + 1))]}
      _robot_f2=${syms[$((RANDOM % ${#syms} + 1))]}
      _robot_f3=${syms[$((RANDOM % ${#syms} + 1))]}
      (( RANDOM % 100 < 15 )) && { _robot_f1='7️⃣'; _robot_f2='7️⃣'; _robot_f3='7️⃣'; }
      _robot_s1='❓'; _robot_s2='❓'; _robot_s3='❓'   # placeholders during pull
    fi

    # While the lever is being pulled, reels stay still.
    if (( _robot_t >= pull_end )); then
      # Per-reel "rotation": rate slows as the reel approaches its stop tick.
      _wt_reel_rate() {
        # arg: ticks remaining until this reel stops
        local r=$1
        if   (( r > 5 )); then echo 1
        elif (( r > 2 )); then echo 2
        else                    echo 3
        fi
      }
      local rate
      local rem1=$(( stop1 - _robot_t ))
      local rem2=$(( stop2 - _robot_t ))
      local rem3=$(( stop3 - _robot_t ))

      if (( _robot_t < stop1 )); then
        rate=$(_wt_reel_rate $rem1)
        (( (_robot_t - pull_end) % rate == 0 )) && _robot_s1=${syms[$((RANDOM % ${#syms} + 1))]}
      else
        _robot_s1=$_robot_f1
      fi
      if (( _robot_t < stop2 )); then
        rate=$(_wt_reel_rate $rem2)
        (( (_robot_t - pull_end) % rate == 0 )) && _robot_s2=${syms[$((RANDOM % ${#syms} + 1))]}
      else
        _robot_s2=$_robot_f2
      fi
      if (( _robot_t < stop3 )); then
        rate=$(_wt_reel_rate $rem3)
        (( (_robot_t - pull_end) % rate == 0 )) && _robot_s3=${syms[$((RANDOM % ${#syms} + 1))]}
      else
        _robot_s3=$_robot_f3
      fi
    fi

    # Fully locked only after the last reel stops.
    if (( _robot_t >= stop3 )); then
      _robot_locked=1
    fi

    local jackpot=0
    [[ -n $_robot_locked && $_robot_f1 == '7️⃣' && $_robot_f2 == '7️⃣' && $_robot_f3 == '7️⃣' ]] && jackpot=1

    # Steady color so the emoji reels stay readable. Only the surrounding
    # sparkles (on jackpot) get the rainbow treatment.
    local slot_color=226   # yellow

    local orange=$'\e[38;5;208m'
    local sc=$'\e[38;5;'"$slot_color"'m'
    local reset=$'\e[39m'

    # Robot uses existing frames. First tick = pulling the lever (arm up).
    # After that the robot stands still while the reels spin, then reacts to
    # the result (jump on jackpot, sad on loss).
    local frame
    if (( _robot_t == 0 )); then
      frame=${idle_frames[3]}     # arm-up — pulling the lever
    elif [[ -z $_robot_locked ]]; then
      frame=${idle_frames[2]}     # standing still, waiting
    elif (( jackpot )); then
      frame=${idle_frames[$(( _robot_t % 2 == 0 ? 9 : 10 ))]}
    else
      frame=${idle_frames[7]}     # sad/slumped
    fi
    local -a r_lines=("${(@f)frame}")

    # Slot machine — 16-col body sized for 2-col emoji reels + side lever knob.
    # Knob position animates the pull: row 1 (up) at t=0, row 2 (mid) while
    # spinning, row 3 (down) after the reels lock.
    local m1 m2 m3 m4
    local base1='.--------------.'
    local base2="| ${_robot_s1} | ${_robot_s2} | ${_robot_s3} |"
    local base3='| -- | -- | -- |'
    local base4="'----[o-o-o]---'"
    if (( _robot_t == 0 )); then
      # Pull moment: lever knob up high, robot grabbing it
      m1="${base1} o"
      m2="${base2}/"
      m3="${base3}"
      m4="${base4}"
    else
      # Pulled: lever knob rests at the bottom while reels spin and lock
      m1="${base1}"
      m2="${base2}"
      m3="${base3}---o"
      m4="${base4}"
    fi

    # No sparkle decoration around the machine — it shifted m1/m4 widths and
    # broke alignment. Celebration is conveyed by the robot's jump frames.

    # Machine on the left, robot pinned to absolute column on the right.
    # The trailing \e[K after the machine clears any stale chars (from the
    # previous frame's lever extension) before the robot is drawn.
    # Total render width ~28 cols (machine 16 + gap + robot ~10). Center
    # the pair horizontally using track (cols - 12 from caller).
    if (( _robot_mirror )); then
      # Mirror layout: robot on left, machine on right, lever on left side of
      # machine ending with knob `o` toward robot (4-col gap reserves space).
      local _slot_off=$(( (track - 30) / 2 ))
      (( _slot_off < 0 )) && _slot_off=0
      local _spad=""
      local _sp; for ((_sp=0; _sp<_slot_off; _sp++)); do _spad+=" "; done
      local mm1 mm2 mm3 mm4
      if (( _robot_t == 0 )); then
        mm1="  o ${base1}"
        mm2="   \\${base2}"
        mm3="    ${base3}"
        mm4="    ${base4}"
      else
        mm1="    ${base1}"
        mm2="    ${base2}"
        mm3="o---${base3}"
        mm4="    ${base4}"
      fi
      local _ml=$(( _slot_off + 10 ))
      printf '%s%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$_spad" "$orange" "${r_lines[1]}" "$reset" "$_ml" "$sc" "$mm1" "$reset"
      printf '%s%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$_spad" "$orange" "${r_lines[2]}" "$reset" "$_ml" "$sc" "$mm2" "$reset"
      printf '%s%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$_spad" "$orange" "${r_lines[3]}" "$reset" "$_ml" "$sc" "$mm3" "$reset"
      printf '%s%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$_spad" "$orange" "${r_lines[4]}" "$reset" "$_ml" "$sc" "$mm4" "$reset"
    else
      # 32-col total layout: machine 0-15, lever 16-19 (`---o`), gap 20-21, robot 22-31.
      local _slot_off=$(( (track - 32) / 2 ))
      (( _slot_off < 0 )) && _slot_off=0
      local _spad=""
      local _sp; for ((_sp=0; _sp<_slot_off; _sp++)); do _spad+=" "; done
      local rc=$(( _slot_off + 22 ))
      printf '%s%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$_spad" "$sc" "$m1" "$reset" "$rc" "$orange" "${r_lines[1]}" "$reset"
      printf '%s%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$_spad" "$sc" "$m2" "$reset" "$rc" "$orange" "${r_lines[2]}" "$reset"
      printf '%s%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$_spad" "$sc" "$m3" "$reset" "$rc" "$orange" "${r_lines[3]}" "$reset"
      printf '%s%s%s%s\e[K\e[%dG%s%s%s\e[K\n' "$_spad" "$sc" "$m4" "$reset" "$rc" "$orange" "${r_lines[4]}" "$reset"
    fi
    (( _robot_t++ ))
    return
    ;;
esac
(( _robot_t++ ))

local pad=""
local _p
for ((_p=0; _p<_robot_pos; _p++)); do pad+=" "; done
local body=${raw//$'\n'/$'\n'$pad}
# Body stays orange; only expression chars between [...] take state color.
local orange=$'\e[38;5;208m'
local accent=$'\e[38;5;'"$color"'m'
local reset=$'\e[39m'
local highlighted=${body//(#b)\[([^]]*)\]/\[${accent}${match[1]}${orange}\]}
# Append \e[K to every line so each row clears its tail when redrawn
highlighted=${highlighted//$'\n'/$'\e[K\n'}
printf '%s%s%s%s\e[K\n' "$orange" "$pad" "$highlighted" "$reset"
