#autoload
# wtclaude — pick a running Claude Code session and cd into its cwd.
# Reads ~/.claude/sessions/*.json, filters live pids, shows arrow picker.

emulate -L zsh
setopt extended_glob no_xtrace no_verbose typeset_silent

# Detect whether installed copy is newer than the version this shell loaded.
# If so, set _wt_restart_tag so the picker shows a "restart shell" banner.
local _wt_restart_tag=""
if [[ -n $WTCLAUDE_DIR && -d $WTCLAUDE_DIR/.git ]]; then
  local _wt_installed=$(git -C "$WTCLAUDE_DIR" describe --tags --abbrev=0 2>/dev/null)
  _wt_installed=${_wt_installed#v}
  if [[ -n $_wt_installed && $_wt_installed != ${WTCLAUDE_VERSION%-*} && $_wt_installed != $WTCLAUDE_VERSION ]]; then
    _wt_restart_tag=$_wt_installed
  fi
fi

local dir=~/.claude/sessions
[[ -d $dir ]] || { echo "no $dir"; return 1; }

# One-shot auto-update: fetch + ff-only pull in background, once per launch.
# No cache, no polling. New version visible on next invocation.
local _wt_update_tag=""
if [[ ${WTCLAUDE_AUTO_UPDATE:-0} == 1 && -d $WTCLAUDE_DIR/.git ]]; then
  ( git -C "$WTCLAUDE_DIR" fetch --quiet --tags origin main 2>/dev/null \
    && git -C "$WTCLAUDE_DIR" pull --ff-only --quiet origin main 2>/dev/null ) &!
fi

local live
live=$(for f in $dir/*.json(N); do
  jq -r 'select(.pid != null) | "\(.updatedAt)\t\(.pid)\t\(.cwd)\t\(.name // "-")"' "$f" 2>/dev/null
done | while IFS=$'\t' read -r ts pid cwd name; do
  kill -0 "$pid" 2>/dev/null && printf '%s\t%s\t%s\t%s\n' "$ts" "$pid" "$cwd" "$name"
done | sort -rn | awk -F'\t' '!seen[$3]++')

[[ -z $live ]] && { echo "no live claude sessions"; return 1; }

# Derive repo roots from live cwds (strip /.claude/worktrees/<name>)
local -A repos seen_cwd
local l_ts l_pid l_cwd l_name repo_root
while IFS=$'\t' read -r l_ts l_pid l_cwd l_name; do
  [[ -z $l_cwd ]] && continue
  seen_cwd[$l_cwd]=1
  repo_root=$l_cwd
  [[ $l_cwd == */.claude/worktrees/* ]] && repo_root=${l_cwd%/.claude/worktrees/*}
  repos[$repo_root]=1
done <<< "$live"

# Append idle worktrees for each known repo + synthesize repo-root entry if missing
local idle="" wt
for repo_root in ${(k)repos}; do
  if [[ -z ${seen_cwd[$repo_root]} && -d $repo_root ]]; then
    local mt0=$(zstat -L +mtime -- "$repo_root" 2>/dev/null || stat -f %m "$repo_root" 2>/dev/null || echo 0)
    idle+="${mt0}000	0	$repo_root	-"$'\n'
    seen_cwd[$repo_root]=1
  fi
  for wt in $repo_root/.claude/worktrees/*(N/); do
    [[ -n ${seen_cwd[$wt]} ]] && continue
    local mt=$(zstat -L +mtime -- "$wt" 2>/dev/null || stat -f %m "$wt" 2>/dev/null || echo 0)
    idle+="${mt}000	0	$wt	-"$'\n'
  done
done

local lines="$live"
[[ -n $idle ]] && lines+=$'\n'"${idle%$'\n'}"

# Group by repo (strip /.claude/worktrees/<name>). Repo root first, then
# worktrees indented. Repos ordered by newest activity. Output: cwd<TAB>name<TAB>indent
lines=$(printf '%s\n' "$lines" | awk -F'\t' '
  {
    ts=$1; cwd=$3; name=$4
    repo=cwd; rank=0
    if (match(cwd, /\/\.claude\/worktrees\//)) { repo=substr(cwd,1,RSTART-1); rank=1 }
    if (!(repo in rts) || ts+0 > rts[repo]+0) rts[repo]=ts
    e_repo[NR]=repo; e_rank[NR]=rank; e_ts[NR]=ts; e_cwd[NR]=cwd; e_name[NR]=name
  }
  END {
    for (i=1; i<=NR; i++)
      printf "%s\t%s\t%s\t%s\t%s\t%s\n", rts[e_repo[i]], e_repo[i], e_rank[i], e_ts[i], e_cwd[i], e_name[i]
  }
' | sort -t$'\t' -k1,1rn -k2,2 -k3,3n -k4,4rn | awk -F'\t' '{printf "%s\t%s\t%s\n", $5, $6, $3}')

local -a items is_last
items=("${(@f)lines}")
local count=${#items}

# Mark last worktree per repo group for tree-line rendering
for ((i=1; i<=count; i++)); do
  local -a fi=(${(s:	:)items[i]})
  local cwd_i=${fi[1]} ind_i=${fi[3]}
  if (( ind_i == 0 )); then
    is_last[i]=0
    continue
  fi
  local repo_i=${cwd_i%/.claude/worktrees/*}
  if (( i == count )); then
    is_last[i]=1
  else
    local -a fn=(${(s:	:)items[i+1]})
    local cwd_n=${fn[1]} ind_n=${fn[3]}
    local repo_n=${cwd_n%/.claude/worktrees/*}
    if [[ $repo_n != $repo_i || $ind_n == 0 ]]; then
      is_last[i]=1
    else
      is_last[i]=0
    fi
  fi
done

local pick
if (( count == 1 )); then
  pick=${items[1]}
else
  local sel=1 key seq aborted=0 frame=0 focused=1 mode=list ssel=1
  local -a settings_keys settings_labels settings_types settings_enum
  settings_keys=(_WT_CHECK_NOW WTCLAUDE_NO_ROBOT WTCLAUDE_AUTO_UPDATE)
  settings_labels=("Check for updates" "Robot animation" "Auto-update")
  settings_types=(action invbool bool)
  local scount=${#settings_keys}
  # Robot state
  local _robot_state="walk" _robot_t=0 _robot_dur=6 _robot_pos=0 _robot_dir=1
  autoload -Uz crazy-robot

  # Helper: persist current settings vars to ~/.config/wtclaude/settings
  _wt_save_settings() {
    local cfg_dir=${XDG_CONFIG_HOME:-$HOME/.config}/wtclaude
    mkdir -p "$cfg_dir" 2>/dev/null
    {
      local k i=0
      for k in $settings_keys; do
        (( i++ ))
        [[ ${settings_types[i]} == action ]] && continue
        printf '%s=%s\n' "$k" "${(P)k:-}"
      done
    } > "$cfg_dir/settings"
  }
  local _wt_check_msg="" _wt_pending_check=0
  _wt_setting_value() {
    local k=$1 t=$2 v=${(P)1:-}
    case $t in
      bool)    [[ $v == 1 ]] && echo true || echo false ;;
      invbool) [[ $v == 1 ]] && echo false || echo true ;;
      action)
        if [[ -n $_wt_update_tag ]]; then
          echo "${_wt_update_tag} available"
        elif [[ -n $_wt_check_msg ]]; then
          echo "$_wt_check_msg"
        else
          echo "press enter"
        fi ;;
    esac
  }
  _wt_check_now() {
    local old_ver=$WTCLAUDE_VERSION
    git -C "$WTCLAUDE_DIR" fetch --quiet --tags --force origin main 2>/dev/null
    local lh=$(git -C "$WTCLAUDE_DIR" rev-parse HEAD 2>/dev/null)
    local rh=$(git -C "$WTCLAUDE_DIR" rev-parse origin/main 2>/dev/null)
    if [[ -n $lh && -n $rh && $lh != $rh ]] \
       && git -C "$WTCLAUDE_DIR" merge-base --is-ancestor "$lh" "$rh" 2>/dev/null; then
      if git -C "$WTCLAUDE_DIR" pull --ff-only --quiet origin main 2>/dev/null; then
        local newtag=$(git -C "$WTCLAUDE_DIR" describe --tags --abbrev=0 2>/dev/null)
        _wt_update_tag=""
        WTCLAUDE_VERSION=${newtag#v}
        _wt_check_msg="updated to v${WTCLAUDE_VERSION}"
      else
        _wt_update_tag=$(git -C "$WTCLAUDE_DIR" describe --tags --abbrev=0 origin/main 2>/dev/null)
        _wt_check_msg="update available"
      fi
    else
      # Commits already match — but a tag-only release may have arrived.
      local new_ver=$(git -C "$WTCLAUDE_DIR" describe --tags --always --dirty 2>/dev/null)
      new_ver=${new_ver#v}
      _wt_update_tag=""
      if [[ -n $new_ver && $new_ver != $old_ver ]]; then
        WTCLAUDE_VERSION=$new_ver
        _wt_check_msg="updated to v${WTCLAUDE_VERSION}"
      else
        _wt_check_msg="no updates"
      fi
    fi
  }
  _wt_setting_toggle() {
    local k=$1 t=$2 v=${(P)1:-}
    case $t in
      bool|invbool)
        if [[ $v == 1 ]]; then eval "$k=0"; else eval "$k=1"; fi ;;
      action)
        [[ $k == _WT_CHECK_NOW ]] && { _wt_check_msg="checking..."; _wt_pending_check=1; } ;;
    esac
  }

  local _wt_stty=$(stty -g 2>/dev/null)
  stty -echo 2>/dev/null
  printf '\e[?1049h\e[?25l\e[?1004h'
  trap 'printf "\e[?25h\e[?1049l\e[?1004l"; [[ -n $_wt_stty ]] && stty "$_wt_stty" 2>/dev/null' EXIT INT TERM
  while true; do
    if (( focused )); then
      printf '\e[H'
      local cols=${COLUMNS:-80}
      local track=$(( cols > 30 ? 30 : cols - 12 ))
      if [[ ${WTCLAUDE_NO_ROBOT:-0} != 1 ]]; then
        crazy-robot $track
      fi
      local sep_w=$(( cols > 60 ? 60 : cols - 2 ))
      local vtag=""
      [[ -n $WTCLAUDE_VERSION ]] && vtag=" v${WTCLAUDE_VERSION} "
      local utag=""
      [[ -n $_wt_update_tag ]] && utag=" ↑ ${_wt_update_tag} available "
      local plain_w=$(( sep_w - ${#vtag} - ${#utag} - 2 ))
      (( plain_w < 0 )) && plain_w=0
      local sep=""
      for ((_s=0; _s<plain_w; _s++)); do sep+="─"; done
      if [[ -n $utag ]]; then
        print -P "%F{240}─%F{208}${utag}%F{240}${sep}%F{238}${vtag}%f"$'\e[K'
      else
        print -P "%F{240}─${sep}%F{238}${vtag}%f"$'\e[K'
      fi
      if [[ -n $_wt_restart_tag ]]; then
        print -P "%F{214}  ↻ v${_wt_restart_tag} installed — restart shell or run 'source \$WTCLAUDE_DIR/wtclaude.plugin.zsh' to apply%f"$'\e[K'
      fi
      if [[ $mode == list ]]; then
        for ((i=1; i<=count; i++)); do
          local row=${items[i]}
          local -a fields=(${(s:	:)row})
          local rcwd=${fields[1]} rname=${fields[2]} rind=${fields[3]}
          local label=$rcwd
          if [[ $rcwd == */worktrees/* ]]; then
            label=${rcwd##*/worktrees/}
            label=${label%%/*}
          fi
          local prefix=""
          if (( rind == 1 )); then
            if (( is_last[i] )); then
              prefix="%F{244}└─%f "
            else
              prefix="%F{244}├─%f "
            fi
          else
            prefix="%F{51}●%f "
          fi
          local suffix=""
          [[ -n $rname && $rname != "-" ]] && suffix="  %F{244}(${rname})%f"
          if (( i == sel )); then
            print -P "${prefix}%F{214}${label}%f${suffix}"$'\e[K'
          else
            print -P "${prefix}${label}${suffix}"$'\e[K'
          fi
        done
        print -P ""$'\e[K'
        print -P "%F{244}↑↓ navigate · Enter pick · → settings · q to quit%f"$'\e[K'
      else
        # Settings panel
        print -P "%F{244}Settings%f"$'\e[K'
        print -P ""$'\e[K'
        local lw=$(( cols > 40 ? 30 : cols / 2 ))
        for ((i=1; i<=scount; i++)); do
          local sk=${settings_keys[i]} sl=${settings_labels[i]} st=${settings_types[i]}
          local sv=$(_wt_setting_value $sk $st)
          local pad=""
          local need=$(( lw - ${#sl} ))
          (( need < 1 )) && need=1
          for ((_p=0; _p<need; _p++)); do pad+=" "; done
          local vcolor=244
          case $sv in
            "no updates"|"updated to "*) vcolor=108 ;;
            "update available"|*"available") vcolor=214 ;;
            "checking..."*)                  vcolor=109 ;;
            true)                            vcolor=108 ;;
            false)                           vcolor=244 ;;
            "press enter")                   vcolor=244 ;;
          esac
          if (( i == ssel )); then
            print -P "  %F{214}${sl}%f${pad}%F{${vcolor}}${sv}%f"$'\e[K'
          else
            print -P "  ${sl}${pad}%F{${vcolor}}${sv}%f"$'\e[K'
          fi
          if [[ ${settings_types[i]} == action && i -lt scount ]]; then
            print -P ""$'\e[K'
          fi
        done
        print -P ""$'\e[K'
        print -P "%F{244}↑↓ navigate · Enter toggle · ← back · Esc quit%f"$'\e[K'
      fi
      printf '\e[J'
    fi
    # Run deferred update check now so "checking..." has been drawn
    if (( _wt_pending_check )); then
      _wt_pending_check=0
      _wt_check_now
      continue
    fi
    # Read with animation timeout when focused; block longer when blurred
    local _timeout
    if (( focused )); then _timeout=0.25; else _timeout=5; fi
    if ! read -t $_timeout -k1 -s key 2>/dev/null; then
      (( focused )) && (( frame++ ))
      continue
    fi
    seq=$key
    if [[ $key == $'\e' ]]; then
      local c
      while read -t 0.05 -k1 -s c 2>/dev/null; do
        seq+=$c
        [[ ${#seq} -ge 3 ]] && break
      done
    fi
    if [[ $mode == list ]]; then
      case $seq in
        $'\e[I') focused=1 ;;
        $'\e[O') focused=0 ;;
        $'\e[A'|k) (( sel = sel == 1 ? count : sel - 1 )) ;;
        $'\e[B'|j) (( sel = sel == count ? 1 : sel + 1 )) ;;
        $'\e[C') mode=settings; ssel=1; printf '\e[H\e[J' ;;
        $'\e'|q|Q) aborted=1; break ;;
        $'\n'|$'\r') break ;;
        ' ')
          [[ ${WTCLAUDE_NO_ROBOT:-0} != 1 ]] && { _robot_state=slot; _robot_t=0; _robot_dur=25; }
          ;;
      esac
    else
      case $seq in
        $'\e[I') focused=1 ;;
        $'\e[O') focused=0 ;;
        $'\e[A'|k) (( ssel = ssel == 1 ? scount : ssel - 1 )) ;;
        $'\e[B'|j) (( ssel = ssel == scount ? 1 : ssel + 1 )) ;;
        $'\n'|$'\r'|' ')
          _wt_setting_toggle ${settings_keys[ssel]} ${settings_types[ssel]}
          _wt_save_settings
          ;;
        $'\e[D'|h) mode=list; printf '\e[H\e[J' ;;
        $'\e'|q|Q) mode=list; printf '\e[H\e[J' ;;
      esac
    fi
    (( focused )) && (( frame++ ))
  done
  # Leave alternate screen + show cursor + restore terminal
  printf '\e[?25h\e[?1049l\e[?1004l'
  [[ -n $_wt_stty ]] && stty "$_wt_stty" 2>/dev/null
  trap - EXIT INT TERM
  (( aborted )) && return 1
  pick=${items[sel]}
fi

local cwd=${${(s:	:)pick}[1]}
[[ -d $cwd ]] && cd "$cwd" || { echo "bad cwd: $cwd"; return 1; }
